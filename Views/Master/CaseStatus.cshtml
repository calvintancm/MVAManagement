@{
    ViewData["Title"] = "Case Statuses";
    ViewData["BreadcrumbSection"] = "Master Data";
    ViewData["BreadcrumbPage"] = "Case Statuses";
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <h1 class="page-title">Case Status Master</h1>
        <p class="page-subtitle">Manage MVA case status codes and display settings</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn-ptc-primary" onclick="openAddRow()">
            <i class="bi bi-plus-lg"></i> Add Status
        </button>
        <button class="btn-ptc-outline" onclick="exportGrid()">
            <i class="bi bi-download"></i> Export
        </button>
    </div>
</div>

@* Info banner *@
<div class="ptc-card mb-3" style="border-left:4px solid #1d6fa4;">
    <div class="ptc-card-body" style="padding:14px 20px;">
        <div style="display:flex;align-items:flex-start;gap:12px;">
            <i class="bi bi-info-circle-fill" style="color:#1d6fa4;font-size:18px;margin-top:2px;flex-shrink:0;"></i>
            <div style="font-size:0.8rem;color:var(--text-muted);line-height:1.6;">
                Status codes drive the case pipeline, dashboard donut chart, and settlement funnel.
                <strong>StatusCode</strong> must be unique (e.g. ACT, NEG, LIT, SET, CLO).
                <strong>DisplayOrder</strong> controls the funnel sort order.
                <strong>HexColor</strong> accepts any CSS hex value (e.g. #185FA5).
            </div>
        </div>
    </div>
</div>

@* Filter Card *@
<div class="ptc-card mb-3">
    <div class="ptc-card-body" style="padding:16px 20px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:14px;">
            <div style="display:flex;flex-direction:column;gap:5px;flex:2;min-width:200px;">
                <label class="filter-label">Status Name / Code</label>
                <input type="text" id="queryStatusName" class="k-textbox"
                       style="width:100%;max-width:280px;" placeholder="Search..." />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:130px;">
                <label class="filter-label">Active</label>
                <select id="queryIsActive" style="width:130px;"></select>
            </div>
            <div style="display:flex;gap:8px;padding-bottom:1px;">
                <button class="btn-ptc-primary" onclick="refreshGrid()">
                    <i class="bi bi-search"></i> Search
                </button>
                <button class="btn-ptc-outline" onclick="clearFilters()">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

@* Grid Card *@
<div class="ptc-card">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title">
            <i class="bi bi-tags"></i> Case Statuses
        </h2>
        <span id="recordCount" class="record-count-badge">0 records</span>
    </div>
    <div class="ptc-card-body" style="padding:0;">
        <div id="main_grid"></div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    kendo.culture('en-GB');

    $('#queryIsActive').kendoDropDownList({
        dataTextField: 'text', dataValueField: 'value',
        dataSource: [
            { text: 'All', value: '' },
            { text: 'Active', value: 'true' },
            { text: 'Inactive', value: 'false' }
        ],
        value: ''
    });

    $('#queryStatusName').on('keypress', function (e) {
        if (e.which === 13) refreshGrid();
    });

    var isMobile = window.innerWidth <= 576;

    $('#main_grid').kendoGrid({
        dataSource: {
            transport: {
                read:    { url: '@Url.Action("CaseStatusRead",    "Master")', type: 'POST' },
                update:  { url: '@Url.Action("CaseStatusUpdate",  "Master")', type: 'POST' },
                create:  { url: '@Url.Action("CaseStatusCreate",  "Master")', type: 'POST' },
                destroy: { url: '@Url.Action("CaseStatusDestroy", "Master")', type: 'POST' },
                parameterMap: function (data, operation) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    if (operation === 'read') {
                        return $.extend({}, data, getFilters(), { __RequestVerificationToken: token });
                    }
                    return $.extend({}, data, { __RequestVerificationToken: token });
                }
            },
            schema: {
                data: 'Data', total: 'Total', errors: 'Errors',
                model: {
                    id: 'Id',
                    fields: {
                        Id:           { type: 'number',  editable: false },
                        StatusCode:   { type: 'string',  validation: { required: true, maxlength: 10 } },
                        StatusName:   { type: 'string',  validation: { required: true } },
                        Description:  { type: 'string'  },
                        HexColor:     { type: 'string',  validation: { required: true } },
                        DisplayOrder: { type: 'number',  validation: { required: true, min: 0 } },
                        IsActive:     { type: 'boolean' },
                        CreatedAt:    { type: 'date',    editable: false },
                        UpdatedAt:    { type: 'date',    editable: false }
                    }
                }
            },
            pageSize: 15, serverPaging: true, serverSorting: true,
            sort: { field: 'DisplayOrder', dir: 'asc' },
            requestEnd: function (e) {
                if (e.type === 'read' && e.response) {
                    var t = e.response.Total || 0;
                    $('#recordCount').text(t + ' record' + (t !== 1 ? 's' : ''));
                }
            },
            error: function (e) { handleGridError(e); }
        },

        columns: [
            { field: 'Id', hidden: true },
            {
                field: 'StatusCode', title: 'Code', width: 90,
                template: '<span style="font-family:monospace;font-weight:700;font-size:0.82rem;">#: StatusCode #</span>'
            },
            {
                field: 'StatusName', title: 'Status Name', width: 160,
                template: function (d) {
                    return '<span style="display:inline-flex;align-items:center;gap:7px;">'
                         + '<span style="width:10px;height:10px;border-radius:50%;background:' + (d.HexColor || '#94A3B8') + ';flex-shrink:0;display:inline-block;"></span>'
                         + '<span style="font-weight:600;">' + kendo.htmlEncode(d.StatusName) + '</span></span>';
                }
            },
            {
                field: 'Description', title: 'Description', width: 220,
                template: '#= Description || "" #'
            },
            {
                field: 'HexColor', title: 'Hex Color', width: 110,
                template: function (d) {
                    var c = d.HexColor || '#94A3B8';
                    return '<span style="display:inline-flex;align-items:center;gap:6px;">'
                         + '<span style="width:18px;height:18px;border-radius:4px;background:' + c + ';border:1px solid rgba(0,0,0,0.1);flex-shrink:0;"></span>'
                         + '<code style="font-size:0.8rem;">' + kendo.htmlEncode(c) + '</code></span>';
                }
            },
            {
                field: 'DisplayOrder', title: 'Order', width: 70,
                attributes: { style: 'text-align:center;' }
            },
            {
                field: 'IsActive', title: 'Active', width: 80,
                attributes: { style: 'text-align:center;' },
                template: '# if(IsActive){ #<span class="badge-active">Active</span># }else{ #<span class="badge-inactive">Inactive</span># } #'
            },
            {
                field: 'UpdatedAt', title: 'Updated', width: 140, hidden: isMobile,
                template: '#= UpdatedAt ? kendo.toString(kendo.parseDate(UpdatedAt), "dd/MM/yyyy HH:mm") : "-" #'
            },
            {
                command: [
                    { name: 'edit', text: { edit: ' Edit', update: ' Save', cancel: ' Cancel' } },
                    {
                        name: 'destroy', text: ' Delete',
                        click: function (e) {
                            e.preventDefault();
                            var row   = $(e.target).closest('tr');
                            var grid  = $('#main_grid').data('kendoGrid');
                            var model = grid.dataItem(row);
                            KSwal.confirmDelete(
                                'Delete Status?',
                                'Delete <strong>' + model.StatusName + ' (' + model.StatusCode + ')</strong>? Cases using this status may be affected.',
                                function () { grid.dataSource.remove(model); grid.dataSource.sync(); }
                            );
                        }
                    }
                ],
                title: 'Action', width: 200
            }
        ],

        editable: 'inline',
        pageable: { pageSize: 15, pageSizes: [15, 30, 50], buttonCount: 5 },
        sortable: true, scrollable: true, height: 520,

        dataBound: function () {
            this.thead.find('th').css({
                background: '#f8fafc', 'font-weight': '600',
                'font-size': '0.77rem', color: '#475569', 'border-color': '#e2e8f0'
            });
        },
        save: function () { KSwal.toast('success', 'Case status saved.'); }
    });

    $('#queryIsActive').data('kendoDropDownList').bind('change', refreshGrid);
    refreshGrid();
});

function getFilters() {
    var ddl = $('#queryIsActive').data('kendoDropDownList');
    return { statusName: $('#queryStatusName').val().trim(), isActive: ddl ? ddl.value() : '' };
}
function refreshGrid() {
    var g = $('#main_grid').data('kendoGrid');
    if (g) g.dataSource.query({ page: 1, pageSize: g.dataSource.pageSize(), sort: g.dataSource.sort() });
}
function clearFilters() {
    $('#queryStatusName').val('');
    var ddl = $('#queryIsActive').data('kendoDropDownList');
    if (ddl) ddl.value('');
    refreshGrid();
}
function openAddRow() {
    var g = $('#main_grid').data('kendoGrid');
    if (g) g.addRow();
}
function exportGrid() {
    var g = $('#main_grid').data('kendoGrid');
    if (g) { g.saveAsExcel(); KSwal.toast('info', 'Exporting...'); }
}
function handleGridError(e) {
    var msg = 'An error occurred.';
    if (e.errors) {
        var parts = [];
        $.each(e.errors, function (k, v) {
            if (v.errors) parts.push(v.errors.join('\n'));
            else if (typeof v === 'string') parts.push(v);
        });
        if (parts.length) msg = parts.join('\n');
    } else if (e.xhr) {
        if (e.xhr.status === 401) msg = 'Session expired.';
        else if (e.xhr.status === 403) msg = 'Access denied.';
        else if (e.xhr.status === 500) msg = 'Server error. Check logs.';
    }
    KSwal.error('Grid Error', msg);
}
</script>
}
