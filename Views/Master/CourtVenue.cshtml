@{
    ViewData["Title"] = "Court Venues";
    ViewData["BreadcrumbSection"] = "Master Data";
    ViewData["BreadcrumbPage"] = "Court Venues";
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <h1 class="page-title">Court Venue Master</h1>
        <p class="page-subtitle">Manage Malaysian court venues used in hearing records</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn-ptc-primary" onclick="openAddRow()">
            <i class="bi bi-plus-lg"></i> Add Venue
        </button>
        <button class="btn-ptc-outline" onclick="exportGrid()">
            <i class="bi bi-download"></i> Export
        </button>
    </div>
</div>

@* Filter Card *@
<div class="ptc-card mb-3">
    <div class="ptc-card-body" style="padding:16px 20px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:14px;">
            <div style="display:flex;flex-direction:column;gap:5px;flex:2;min-width:200px;">
                <label class="filter-label">Venue Name / Code</label>
                <input type="text" id="queryVenueName" class="k-textbox"
                       style="width:100%;max-width:300px;" placeholder="Search venue or code..." />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:180px;">
                <label class="filter-label">Jurisdiction</label>
                <input type="text" id="queryJurisdiction" class="k-textbox"
                       style="width:180px;" placeholder="e.g. Kuala Lumpur..." />
            </div>
            <div style="display:flex;gap:8px;padding-bottom:1px;">
                <button class="btn-ptc-primary" onclick="refreshGrid()">
                    <i class="bi bi-search"></i> Search
                </button>
                <button class="btn-ptc-outline" onclick="clearFilters()">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

@* Grid Card *@
<div class="ptc-card">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title">
            <i class="bi bi-geo-alt"></i> Court Venues
        </h2>
        <span id="recordCount" class="record-count-badge">0 records</span>
    </div>
    <div class="ptc-card-body" style="padding:0;">
        <div id="main_grid"></div>
    </div>
</div>

@section Scripts {
<script>
var malaysianJurisdictions = [
    'Johor Bahru','Kluang','Muar','Batu Pahat',
    'Kuala Lumpur','Putrajaya',
    'Shah Alam','Petaling Jaya','Klang',
    'Ipoh','Taiping',
    'George Town','Butterworth',
    'Kota Kinabalu','Sandakan',
    'Kuching','Miri','Sibu',
    'Seremban','Melaka','Alor Setar',
    'Kota Bharu','Kuala Terengganu','Kuantan'
];

$(function () {
    kendo.culture('en-GB');

    $('#queryVenueName, #queryJurisdiction').on('keypress', function (e) {
        if (e.which === 13) refreshGrid();
    });

    var isMobile = window.innerWidth <= 576;

    $('#main_grid').kendoGrid({
        dataSource: {
            transport: {
                read:    { url: '@Url.Action("CourtVenueRead",    "Master")', type: 'POST' },
                update:  { url: '@Url.Action("CourtVenueUpdate",  "Master")', type: 'POST' },
                create:  { url: '@Url.Action("CourtVenueCreate",  "Master")', type: 'POST' },
                destroy: { url: '@Url.Action("CourtVenueDestroy", "Master")', type: 'POST' },
                parameterMap: function (data, operation) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    if (operation === 'read')
                        return $.extend({}, data, getFilters(), { __RequestVerificationToken: token });
                    return $.extend({}, data, { __RequestVerificationToken: token });
                }
            },
            schema: {
                data: 'Data', total: 'Total', errors: 'Errors',
                model: {
                    id: 'Id',
                    fields: {
                        Id:            { type: 'number', editable: false },
                        VenueName:     { type: 'string', validation: { required: true } },
                        VenueCode:     { type: 'string' },
                        Jurisdiction:  { type: 'string' },
                        Address:       { type: 'string' },
                        ContactNumber: { type: 'string' }
                    }
                }
            },
            pageSize: 15, serverPaging: true, serverSorting: true,
            sort: { field: 'VenueName', dir: 'asc' },
            requestEnd: function (e) {
                if (e.type === 'read' && e.response) {
                    var t = e.response.Total || 0;
                    $('#recordCount').text(t + ' record' + (t !== 1 ? 's' : ''));
                }
            },
            error: function (e) { handleGridError(e); }
        },

        columns: [
            { field: 'Id', hidden: true },
            {
                field: 'VenueCode', title: 'Code', width: 90,
                template: function (d) {
                    if (!d.VenueCode) return '<span style="color:#94a3b8;">—</span>';
                    return '<span style="font-family:monospace;font-weight:700;font-size:0.82rem;'
                         + 'background:#e0e7ff;color:#3730a3;padding:2px 8px;border-radius:20px;">'
                         + kendo.htmlEncode(d.VenueCode) + '</span>';
                }
            },
            {
                field: 'VenueName', title: 'Venue Name', width: 260,
                template: '<span style="font-weight:600;">#: VenueName #</span>'
            },
            {
                field: 'Jurisdiction', title: 'Jurisdiction', width: 170,
                template: function (d) {
                    if (!d.Jurisdiction) return '<span style="color:#94a3b8;">—</span>';
                    return '<span style="background:#dcfce7;color:#166534;padding:2px 10px;'
                         + 'border-radius:20px;font-size:0.75rem;font-weight:600;">'
                         + kendo.htmlEncode(d.Jurisdiction) + '</span>';
                },
                editor: function (container, options) {
                    $('<input name="' + options.field + '"/>').appendTo(container).kendoDropDownList({
                        dataSource: malaysianJurisdictions,
                        value: options.model.Jurisdiction,
                        optionLabel: '— Select —'
                    });
                }
            },
            {
                field: 'Address', title: 'Address', width: 240, hidden: isMobile,
                template: '#= Address || "-" #'
            },
            {
                field: 'ContactNumber', title: 'Contact No.', width: 130, hidden: isMobile,
                template: function (d) {
                    if (!d.ContactNumber) return '<span style="color:#94a3b8;">—</span>';
                    return '<a href="tel:' + kendo.htmlEncode(d.ContactNumber) + '" style="color:#1d6fa4;">'
                         + kendo.htmlEncode(d.ContactNumber) + '</a>';
                }
            },
            {
                command: [
                    { name: 'edit', text: { edit: ' Edit', update: ' Save', cancel: ' Cancel' } },
                    {
                        name: 'destroy', text: ' Delete',
                        click: function (e) {
                            e.preventDefault();
                            var grid  = $('#main_grid').data('kendoGrid');
                            var model = grid.dataItem($(e.target).closest('tr'));
                            KSwal.confirmDelete(
                                'Delete Venue?',
                                'Delete <strong>' + model.VenueName + '</strong>?'
                                + ' Hearing records referencing this venue will be affected.',
                                function () { grid.dataSource.remove(model); grid.dataSource.sync(); }
                            );
                        }
                    }
                ],
                title: 'Action', width: 200
            }
        ],

        editable: 'inline',
        pageable: { pageSize: 15, pageSizes: [15, 30, 50], buttonCount: 5 },
        sortable: true, scrollable: true, height: 520,
        dataBound: function () {
            this.thead.find('th').css({
                background: '#f8fafc', 'font-weight': '600',
                'font-size': '0.77rem', color: '#475569', 'border-color': '#e2e8f0'
            });
        },
        save: function () { KSwal.toast('success', 'Court venue saved.'); }
    });

    refreshGrid();
});

function getFilters() {
    return {
        venueName:    $('#queryVenueName').val().trim(),
        jurisdiction: $('#queryJurisdiction').val().trim()
    };
}
function refreshGrid() {
    var g = $('#main_grid').data('kendoGrid');
    if (g) g.dataSource.query({ page: 1, pageSize: g.dataSource.pageSize(), sort: g.dataSource.sort() });
}
function clearFilters() {
    $('#queryVenueName').val('');
    $('#queryJurisdiction').val('');
    refreshGrid();
}
function openAddRow() { var g = $('#main_grid').data('kendoGrid'); if (g) g.addRow(); }
function exportGrid() { var g = $('#main_grid').data('kendoGrid'); if (g) { g.saveAsExcel(); KSwal.toast('info', 'Exporting...'); } }
function handleGridError(e) {
    var msg = 'An error occurred.';
    if (e.errors) {
        var p = [];
        $.each(e.errors, function (k, v) {
            if (v.errors) p.push(v.errors.join('\n'));
            else if (typeof v === 'string') p.push(v);
        });
        if (p.length) msg = p.join('\n');
    } else if (e.xhr) {
        if (e.xhr.status === 401) msg = 'Session expired.';
        else if (e.xhr.status === 403) msg = 'Access denied.';
        else if (e.xhr.status === 500) msg = 'Server error. Check logs.';
    }
    KSwal.error('Grid Error', msg);
}
</script>
}
