@model MVAManagement.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — FrostChain Distribution</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/limonte-sweetalert2/11.10.1/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/limonte-sweetalert2/11.10.1/sweetalert2.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --deep:       #0c1e35;
            --mid:        #132d4a;
            --card:       #1a3a5c;
            --frost:      #e8f4fd;
            --ice:        #c8e6f5;
            --accent:     #f5820a;
            --accent-lt:  #ffaa45;
            --accent-glow:rgba(245,130,10,0.28);
            --cyan:       #00c6e0;
            --cyan-lt:    #7de8f5;
            --cyan-dim:   rgba(0,198,224,0.12);
            --white:      #ffffff;
            --muted:      #6b97b8;
            --muted-lt:   #9bbdd4;
            --border:     rgba(255,255,255,0.07);
            --border-act: rgba(0,198,224,0.45);
            --input-bg:   rgba(255,255,255,0.04);
            --error:      #ff5f6d;
            --radius:     16px;
        }

        html, body {
            height: 100%;
            font-family: 'Outfit', sans-serif;
            background: var(--deep);
            color: var(--white);
            overflow: hidden;
        }

        /* ═══════════════════════════════════════
           LAYOUT
           ═══════════════════════════════════════ */
        .login-wrapper {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* ═══════════════════════════════════════
           LEFT PANEL
           ═══════════════════════════════════════ */
        .panel-left {
            flex: 1.15;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            padding: 48px;
            background: linear-gradient(155deg, #0e2540 0%, #0c1e35 45%, #091828 100%);
        }

        /* Hexagonal grid overlay */
        .hex-grid {
            position: absolute;
            inset: 0;
            opacity: 0.06;
            background-image:
                repeating-linear-gradient(60deg,  rgba(0,198,224,1) 0, rgba(0,198,224,1) 1px, transparent 0, transparent 50%),
                repeating-linear-gradient(120deg, rgba(0,198,224,1) 0, rgba(0,198,224,1) 1px, transparent 0, transparent 50%),
                repeating-linear-gradient(180deg, rgba(0,198,224,1) 0, rgba(0,198,224,1) 1px, transparent 0, transparent 50%);
            background-size: 36px 62px;
        }

        /* Frost orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            animation: float 9s ease-in-out infinite;
        }
        .orb-1 {
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(0,198,224,0.22), transparent 70%);
            top: -120px; left: -100px;
            animation-delay: 0s;
        }
        .orb-2 {
            width: 360px; height: 360px;
            background: radial-gradient(circle, rgba(245,130,10,0.18), transparent 70%);
            bottom: -60px; right: -60px;
            animation-delay: -4s;
        }
        .orb-3 {
            width: 250px; height: 250px;
            background: radial-gradient(circle, rgba(0,198,224,0.14), transparent 70%);
            bottom: 160px; left: 60px;
            animation-delay: -7s;
        }
        @@keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50%       { transform: translateY(-22px) scale(1.03); }
        }

        /* Frost particles */
        .particles { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
        .particle {
            position: absolute;
            border-radius: 50%;
            background: rgba(200,230,245,0.55);
            animation: drift linear infinite;
        }
        @@keyframes drift {
            0%   { transform: translateY(110vh) rotate(0deg);   opacity: 0; }
            10%  { opacity: 1; }
            90%  { opacity: 0.6; }
            100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
        }

        /* ── Illustration ── */
        .illustration-wrap {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 44px;
            animation: slide-in-left 0.7s cubic-bezier(0.22,1,0.36,1) both;
            animation-delay: 0.1s;
        }
        @@keyframes slide-in-left {
            from { opacity: 0; transform: translateX(-28px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        .illustration-svg {
            width: 360px; height: auto;
            filter: drop-shadow(0 24px 64px rgba(0,198,224,0.25));
            animation: hover-svg 6s ease-in-out infinite;
        }
        @@keyframes hover-svg {
            0%, 100% { transform: translateY(0); }
            50%       { transform: translateY(-14px); }
        }

        /* Brand block */
        .brand-block { text-align: center; }
        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 13px;
            margin-bottom: 14px;
        }
        .brand-icon {
            width: 46px; height: 46px;
            background: linear-gradient(135deg, var(--accent), var(--accent-lt));
            border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 20px var(--accent-glow);
        }
        .brand-icon svg { width: 26px; height: 26px; fill: white; }
        .brand-name {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.45rem;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -0.4px;
        }
        .brand-tagline {
            font-size: 0.9rem;
            color: var(--muted-lt);
            font-weight: 300;
            line-height: 1.65;
            max-width: 300px;
            margin: 0 auto;
        }

        /* Feature pills */
        .feature-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 20px;
        }
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(0,198,224,0.10);
            border: 1px solid rgba(0,198,224,0.22);
            border-radius: 20px;
            padding: 5px 13px;
            font-size: 0.74rem;
            font-weight: 500;
            color: var(--cyan-lt);
            letter-spacing: 0.02em;
        }
        .pill-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--cyan);
            flex-shrink: 0;
        }

        /* Stats */
        .stats-row {
            display: flex;
            gap: 28px;
            margin-top: 22px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }
        .stat-item { text-align: center; }
        .stat-num {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--accent);
            display: block;
            line-height: 1;
            margin-bottom: 4px;
        }
        .stat-label {
            font-size: 0.68rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ═══════════════════════════════════════
           RIGHT PANEL — FORM
           ═══════════════════════════════════════ */
        .panel-right {
            flex: 0.85;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--mid);
            position: relative;
            padding: 48px 52px;
            overflow: hidden;
        }

        /* Top cyan accent bar */
        .panel-right::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent 0%, var(--cyan) 40%, var(--accent) 70%, transparent 100%);
        }

        /* Corner decoration */
        .panel-right::after {
            content: '';
            position: absolute;
            bottom: -80px; right: -80px;
            width: 260px; height: 260px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,198,224,0.06), transparent 70%);
            pointer-events: none;
        }

        /* Temperature badge (decorative) */
        .temp-badge {
            position: absolute;
            top: 22px; right: 22px;
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(0,198,224,0.1);
            border: 1px solid rgba(0,198,224,0.2);
            border-radius: 20px;
            padding: 5px 12px 5px 9px;
            font-size: 0.73rem;
            font-weight: 500;
            color: var(--cyan-lt);
        }
        .temp-indicator {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--cyan);
            box-shadow: 0 0 6px var(--cyan);
            animation: pulse 2s ease-in-out infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(0.8); }
        }

        /* Form card */
        .form-card {
            width: 100%;
            max-width: 390px;
            position: relative;
            z-index: 1;
            animation: slide-up 0.55s cubic-bezier(0.22,1,0.36,1) both;
        }
        @@keyframes slide-up {
            from { opacity: 0; transform: translateY(26px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Form header */
        .form-header { margin-bottom: 38px; }
        .form-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--cyan);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            margin-bottom: 12px;
        }
        .eyebrow-line {
            width: 24px; height: 1.5px;
            background: var(--cyan);
            border-radius: 2px;
        }
        .form-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--white);
            line-height: 1.12;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }
        .form-title span { color: var(--cyan); }
        .form-subtitle {
            font-size: 0.88rem;
            color: var(--muted-lt);
            font-weight: 300;
            line-height: 1.5;
        }

        /* Error alert */
        .alert-error {
            background: rgba(255,95,109,0.08);
            border: 1px solid rgba(255,95,109,0.25);
            border-left: 3px solid var(--error);
            border-radius: 10px;
            padding: 13px 15px;
            margin-bottom: 26px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            animation: shake 0.4s ease;
        }
        @@keyframes shake {
            0%,100% { transform: translateX(0); }
            20%      { transform: translateX(-5px); }
            40%      { transform: translateX(5px); }
            60%      { transform: translateX(-3px); }
            80%      { transform: translateX(3px); }
        }
        .alert-error-icon { color: var(--error); flex-shrink: 0; margin-top: 1px; }
        .alert-error-text { font-size: 0.85rem; color: #ffb0b5; line-height: 1.45; }

        /* Field groups */
        .field-group { margin-bottom: 20px; }
        .field-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.76rem;
            font-weight: 600;
            color: var(--muted-lt);
            text-transform: uppercase;
            letter-spacing: 0.09em;
            margin-bottom: 9px;
        }
        .field-wrap { position: relative; }

        .field-input {
            width: 100%;
            background: var(--input-bg);
            border: 1.5px solid var(--border);
            border-radius: 11px;
            padding: 13px 16px 13px 46px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.93rem;
            color: var(--white);
            outline: none;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }
        .field-input::placeholder { color: #2d5070; }
        .field-input:focus {
            border-color: var(--cyan);
            background: var(--cyan-dim);
            box-shadow: 0 0 0 4px rgba(0,198,224,0.1);
        }

        .field-icon {
            position: absolute;
            left: 15px; top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
            display: flex;
            transition: color 0.2s;
        }
        .field-icon svg { width: 17px; height: 17px; }
        .field-wrap:focus-within .field-icon { color: var(--cyan); }

        .field-toggle {
            position: absolute;
            right: 13px; top: 50%;
            transform: translateY(-50%);
            background: none; border: none;
            cursor: pointer; color: var(--muted);
            display: flex; align-items: center;
            padding: 4px;
            transition: color 0.2s;
        }
        .field-toggle:hover { color: var(--cyan); }
        .field-toggle svg { width: 17px; height: 17px; }
        .field-input.has-toggle { padding-right: 44px; }

        .validation-msg {
            font-size: 0.77rem;
            color: var(--error);
            margin-top: 6px;
            display: flex; align-items: center; gap: 5px;
        }

        /* Options row */
        .options-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 26px;
        }
        .remember-label {
            display: flex; align-items: center; gap: 9px;
            cursor: pointer; font-size: 0.84rem;
            color: var(--muted-lt); user-select: none;
        }
        .remember-check {
            width: 16px; height: 16px;
            accent-color: var(--cyan); cursor: pointer;
        }
        .forgot-link {
            font-size: 0.82rem;
            color: var(--accent-lt);
            text-decoration: none;
            opacity: 0.85;
            transition: opacity 0.15s;
        }
        .forgot-link:hover { opacity: 1; text-decoration: underline; }

        /* Submit button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-lt) 100%);
            border: none;
            border-radius: 11px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.93rem;
            font-weight: 700;
            color: #1a0800;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative; overflow: hidden;
            letter-spacing: 0.01em;
        }
        .btn-login::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.18), transparent);
            opacity: 0;
            transition: opacity 0.2s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 36px rgba(245,130,10,0.42);
        }
        .btn-login:hover::before { opacity: 1; }
        .btn-login:active { transform: translateY(0); }
        .btn-login:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .btn-login .spinner {
            display: none;
            width: 18px; height: 18px;
            border: 2px solid rgba(26,8,0,0.25);
            border-top-color: #1a0800;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            margin: 0 auto;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .btn-login.loading .btn-text { display: none; }
        .btn-login.loading .spinner  { display: block; }

        /* OR divider */
        .divider {
            display: flex; align-items: center; gap: 12px;
            margin: 22px 0 0;
        }
        .divider-line { flex: 1; height: 1px; background: var(--border); }
        .divider-text { font-size: 0.73rem; color: var(--muted); }

        /* Footer */
        .form-footer {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
            font-size: 0.76rem;
            color: var(--muted);
            line-height: 1.7;
        }
        .form-footer strong { color: var(--muted-lt); font-weight: 500; }

        /* ═══════════════════════════════════════
           RESPONSIVE
           ═══════════════════════════════════════ */
        @@media (max-width: 920px) {
            .panel-left { display: none; }
            .panel-right { flex: 1; padding: 32px 24px; background: var(--deep); }
        }
        @@media (max-width: 480px) {
            .panel-right { padding: 24px 18px; }
            .form-title { font-size: 1.65rem; }
        }
    </style>
</head>
<body>
<div class="login-wrapper">

    <!-- ══ LEFT PANEL ═══════════════════════════════════════════ -->
    <div class="panel-left">
        <div class="hex-grid"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <!-- Floating frost particles (generated by JS) -->
        <div class="particles" id="particles"></div>

        <div class="illustration-wrap">

            <!-- Cold-chain warehouse SVG illustration -->
            <svg class="illustration-svg" viewBox="0 0 420 340" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <radialGradient id="glow-cyan" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="#00c6e0" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="#00c6e0" stop-opacity="0"/>
                    </radialGradient>
                    <radialGradient id="glow-orange" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="#f5820a" stop-opacity="0.35"/>
                        <stop offset="100%" stop-color="#f5820a" stop-opacity="0"/>
                    </radialGradient>
                    <linearGradient id="wall-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#1a3a5c"/>
                        <stop offset="100%" stop-color="#112d48"/>
                    </linearGradient>
                    <linearGradient id="roof-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#22496e"/>
                        <stop offset="100%" stop-color="#1a3a5c"/>
                    </linearGradient>
                    <filter id="blur-sm">
                        <feGaussianBlur stdDeviation="2"/>
                    </filter>
                </defs>

                <!-- Ground / shadow -->
                <ellipse cx="210" cy="322" rx="160" ry="11" fill="rgba(0,0,0,0.28)"/>
                <rect x="20" y="300" width="380" height="18" rx="5" fill="#0f2236"/>

                <!-- ── Warehouse building ── -->
                <!-- Main body -->
                <rect x="60" y="150" width="300" height="152" rx="4" fill="url(#wall-grad)" stroke="#1e4570" stroke-width="1.5"/>
                <!-- Roof -->
                <polygon points="40,152 210,90 380,152" fill="url(#roof-grad)" stroke="#22537f" stroke-width="1.5"/>
                <!-- Roof ridge highlight -->
                <line x1="210" y1="90" x2="210" y2="150" stroke="rgba(0,198,224,0.25)" stroke-width="1"/>

                <!-- Glow behind building -->
                <ellipse cx="210" cy="220" rx="180" ry="100" fill="url(#glow-cyan)" filter="url(#blur-sm)" opacity="0.5"/>

                <!-- ── Loading dock / door ── -->
                <rect x="150" y="220" width="120" height="80" rx="3" fill="#0d2035" stroke="#1a3a5c" stroke-width="1.5"/>
                <!-- Door frame highlight -->
                <rect x="152" y="222" width="116" height="78" rx="2" fill="none" stroke="rgba(0,198,224,0.2)" stroke-width="1"/>
                <!-- Door stripes -->
                <line x1="150" y1="247" x2="270" y2="247" stroke="#162d47" stroke-width="1.5"/>
                <line x1="150" y1="265" x2="270" y2="265" stroke="#162d47" stroke-width="1.5"/>
                <line x1="150" y1="283" x2="270" y2="283" stroke="#162d47" stroke-width="1.5"/>
                <!-- Warning stripes on dock -->
                <rect x="155" y="294" width="24" height="6" rx="1" fill="#f5820a" opacity="0.7"/>
                <rect x="195" y="294" width="24" height="6" rx="1" fill="#f5820a" opacity="0.7"/>
                <rect x="235" y="294" width="24" height="6" rx="1" fill="#f5820a" opacity="0.7"/>

                <!-- ── Windows ── -->
                <rect x="78"  y="175" width="50" height="38" rx="3" fill="#0d2640" stroke="#1e4570" stroke-width="1"/>
                <rect x="78"  y="175" width="50" height="38" rx="3" fill="rgba(0,198,224,0.08)"/>
                <line x1="103" y1="175" x2="103" y2="213" stroke="#1e4570" stroke-width="1"/>
                <line x1="78"  y1="194" x2="128" y2="194" stroke="#1e4570" stroke-width="1"/>
                <!-- Window glow -->
                <rect x="79"  y="176" width="48" height="36" rx="2" fill="rgba(0,198,224,0.06)"/>

                <rect x="292" y="175" width="50" height="38" rx="3" fill="#0d2640" stroke="#1e4570" stroke-width="1"/>
                <rect x="292" y="175" width="50" height="38" rx="3" fill="rgba(0,198,224,0.08)"/>
                <line x1="317" y1="175" x2="317" y2="213" stroke="#1e4570" stroke-width="1"/>
                <line x1="292" y1="194" x2="342" y2="194" stroke="#1e4570" stroke-width="1"/>

                <!-- ── Forklift (left) ── -->
                <g transform="translate(68,225)">
                    <!-- Body -->
                    <rect x="0" y="22" width="44" height="30" rx="3" fill="#1a4a78" stroke="#2060a0" stroke-width="1"/>
                    <!-- Mast -->
                    <rect x="38" y="0" width="6" height="52" rx="2" fill="#1e5480" stroke="#2060a0" stroke-width="1"/>
                    <!-- Forks -->
                    <rect x="44" y="44" width="28" height="4" rx="1" fill="#2a6aaa"/>
                    <rect x="44" y="50" width="28" height="4" rx="1" fill="#2a6aaa"/>
                    <!-- Pallet on forks -->
                    <rect x="46" y="32" width="26" height="12" rx="2" fill="#1a3050" stroke="#2a4a6a" stroke-width="1"/>
                    <rect x="48" y="34" width="22" height="8" rx="1" fill="#00c6e0" opacity="0.3"/>
                    <!-- Wheel -->
                    <circle cx="10" cy="52" r="7" fill="#0d1a2e" stroke="#1e3a5c" stroke-width="1.5"/>
                    <circle cx="10" cy="52" r="3" fill="#1a3a5c"/>
                    <circle cx="34" cy="52" r="7" fill="#0d1a2e" stroke="#1e3a5c" stroke-width="1.5"/>
                    <circle cx="34" cy="52" r="3" fill="#1a3a5c"/>
                </g>

                <!-- ── Frozen crates / pallets ── -->
                <!-- Pallet stack right -->
                <g transform="translate(300,248)">
                    <rect x="0"  y="24" width="52" height="8"  rx="2" fill="#1a3a5c" stroke="#2a5080" stroke-width="1"/>
                    <rect x="4"  y="12" width="44" height="14" rx="3" fill="#1e4070" stroke="#2a5080" stroke-width="1"/>
                    <rect x="4"  y="12" width="44" height="14" rx="3" fill="rgba(0,198,224,0.12)"/>
                    <rect x="4"  y="0"  width="44" height="14" rx="3" fill="#223a60" stroke="#2a5080" stroke-width="1"/>
                    <rect x="4"  y="0"  width="44" height="14" rx="3" fill="rgba(0,198,224,0.08)"/>
                    <!-- Cold label -->
                    <rect x="16" y="4" width="20" height="8" rx="1" fill="#00c6e0" opacity="0.25"/>
                    <text x="26" y="10" font-family="Outfit,sans-serif" font-size="5" fill="#7de8f5" text-anchor="middle" font-weight="600">COLD</text>
                </g>

                <!-- Scattered boxes floating -->
                <g opacity="0.88" transform="translate(30,88)">
                    <rect x="0" y="0" width="40" height="36" rx="4" fill="#163050" stroke="#1e4570" stroke-width="1.3"/>
                    <line x1="0" y1="18" x2="40" y2="18" stroke="#1e4570" stroke-width="1"/>
                    <line x1="20" y1="0" x2="20" y2="36" stroke="#1e4570" stroke-width="1"/>
                    <rect x="5" y="4" width="10" height="7" rx="1" fill="#f5820a" opacity="0.55"/>
                    <!-- Snowflake icon on box -->
                    <text x="20" y="32" font-family="sans-serif" font-size="8" fill="#00c6e0" text-anchor="middle" opacity="0.6">❄</text>
                </g>
                <g opacity="0.8" transform="translate(350,72)">
                    <rect x="0" y="0" width="44" height="40" rx="4" fill="#163050" stroke="#1e4570" stroke-width="1.3"/>
                    <line x1="0" y1="20" x2="44" y2="20" stroke="#1e4570" stroke-width="1"/>
                    <line x1="22" y1="0" x2="22" y2="40" stroke="#1e4570" stroke-width="1"/>
                    <rect x="5" y="4" width="12" height="8" rx="1" fill="#f5820a" opacity="0.55"/>
                    <text x="22" y="36" font-family="sans-serif" font-size="8" fill="#00c6e0" text-anchor="middle" opacity="0.6">❄</text>
                </g>
                <g opacity="0.65" transform="translate(170,52)">
                    <rect x="0" y="0" width="36" height="32" rx="4" fill="#163050" stroke="#1e4570" stroke-width="1.3"/>
                    <line x1="0" y1="16" x2="36" y2="16" stroke="#1e4570" stroke-width="1"/>
                    <line x1="18" y1="0" x2="18" y2="32" stroke="#1e4570" stroke-width="1"/>
                    <text x="18" y="28" font-family="sans-serif" font-size="7" fill="#00c6e0" text-anchor="middle" opacity="0.5">❄</text>
                </g>

                <!-- Route / flow path between boxes -->
                <path d="M50 106 Q100 50 188 68 Q270 86 350 90" stroke="#00c6e0" stroke-width="1.2"
                      stroke-dasharray="5 4" fill="none" opacity="0.3"/>

                <!-- Temperature sensor -->
                <g transform="translate(194,40)">
                    <circle cx="16" cy="16" r="18" fill="url(#glow-orange)" opacity="0.8"/>
                    <circle cx="16" cy="16" r="11" fill="#1a3050" stroke="#f5820a" stroke-width="1.5"/>
                    <text x="16" y="20" font-family="Outfit,sans-serif" font-size="8" fill="#f5820a"
                          text-anchor="middle" font-weight="700">-18°</text>
                </g>

                <!-- Snowflake particles floating around warehouse -->
                <text x="95"  y="130" font-family="sans-serif" font-size="12" fill="#00c6e0" opacity="0.35">❄</text>
                <text x="310" y="125" font-family="sans-serif" font-size="10" fill="#00c6e0" opacity="0.3">❄</text>
                <text x="200" y="145" font-family="sans-serif" font-size="8"  fill="#7de8f5" opacity="0.25">❄</text>
                <text x="140" y="110" font-family="sans-serif" font-size="9"  fill="#00c6e0" opacity="0.2">❄</text>
            </svg>

            <!-- Brand block -->
            <div class="brand-block">
                <div class="brand-logo">
                    <div class="brand-icon">
                        <!-- Snowflake / cold-chain icon -->
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22v-2z"/>
                        </svg>
                    </div>
                    <span class="brand-name">FrostChain DC</span>
                </div>
                <p class="brand-tagline">
                    Frozen Foods Distribution Centre<br>Management &amp; Operations System
                </p>

                <div class="feature-pills">
                    <span class="pill"><span class="pill-dot"></span>Cold Chain Tracking</span>
                    <span class="pill"><span class="pill-dot"></span>Temp Monitoring</span>
                    <span class="pill"><span class="pill-dot"></span>Inventory Control</span>
                </div>

                <div class="stats-row">
                    <div class="stat-item">
                        <span class="stat-num">-18°C</span>
                        <span class="stat-label">Storage Temp</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-num">99.9%</span>
                        <span class="stat-label">Uptime</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-num">24/7</span>
                        <span class="stat-label">Monitoring</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ RIGHT PANEL ══════════════════════════════════════════ -->
    <div class="panel-right">

        <!-- Temperature status badge -->
        <div class="temp-badge">
            <div class="temp-indicator"></div>
            System Online
        </div>

        <div class="form-card">

            <div class="form-header">
                <div class="form-eyebrow">
                    <span class="eyebrow-line"></span>
                    Secure Portal
                </div>
                <h1 class="form-title">Welcome <span>Back</span></h1>
                <p class="form-subtitle">Sign in to access the distribution management system.</p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-error">
                    <span class="alert-error-icon">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                        </svg>
                    </span>
                    <span class="alert-error-text">@TempData["ErrorMessage"]</span>
                </div>
            }

            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl },
                            FormMethod.Post, null, new { id = "loginForm", autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()

                <!-- Username -->
                <div class="field-group">
                    <label class="field-label" for="UserName">Username</label>
                    <div class="field-wrap">
                        @Html.TextBoxFor(m => m.UserName, new {
                            id = "UserName",
                            @class = "field-input",
                            placeholder = "Enter your username",
                            autocomplete = "username",
                            spellcheck = "false"
                        })
                        <span class="field-icon">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                            </svg>
                        </span>
                    </div>
                    @if (ViewData.ModelState["UserName"]?.Errors.Count > 0)
                    {
                        <div class="validation-msg">@Html.ValidationMessageFor(m => m.UserName)</div>
                    }
                </div>

                <!-- Password -->
                <div class="field-group">
                    <label class="field-label" for="Password">Password</label>
                    <div class="field-wrap">
                        @Html.PasswordFor(m => m.Password, new {
                            id = "Password",
                            @class = "field-input has-toggle",
                            placeholder = "Enter your password",
                            autocomplete = "current-password"
                        })
                        <span class="field-icon">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>
                            </svg>
                        </span>
                        <button type="button" class="field-toggle" id="togglePwd" title="Show/hide password">
                            <svg id="eyeIcon" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                            </svg>
                        </button>
                    </div>
                    @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                    {
                        <div class="validation-msg">@Html.ValidationMessageFor(m => m.Password)</div>
                    }
                </div>

                <!-- Options row -->
                <div class="options-row">
                    <label class="remember-label">
                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "remember-check" })
                        Remember me for 8 hours
                    </label>
                    <a href="javascript:void(0)" class="forgot-link" onclick="showForgotPassword()">
                        Forgot password?
                    </a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-login" id="loginBtn">
                    <span class="btn-text">Sign In</span>
                    <span class="spinner"></span>
                </button>
            }

            <div class="form-footer">
                <p>Having trouble? Contact your <strong>system administrator</strong>.</p>
                <p style="margin-top:6px;">&copy; @DateTime.Now.Year FrostChain DC &mdash; v1.0</p>
            </div>

        </div>
    </div>
</div>

<script>
    /* ── Frost particles ─────────────────────────────────────── */
    (function () {
        var container = document.getElementById('particles');
        for (var i = 0; i < 18; i++) {
            var p = document.createElement('div');
            p.className = 'particle';
            var size = Math.random() * 4 + 2;
            p.style.cssText = [
                'width:'    + size + 'px',
                'height:'   + size + 'px',
                'left:'     + (Math.random() * 100) + '%',
                'top:'      + (Math.random() * 100) + '%',
                'animation-duration:'  + (Math.random() * 14 + 10) + 's',
                'animation-delay:' + (Math.random() * -14) + 's',
                'opacity:'  + (Math.random() * 0.5 + 0.2)
            ].join(';');
            container.appendChild(p);
        }
    })();

    /* ── Forgot password ─────────────────────────────────────── */
    function showForgotPassword() {
        Swal.fire({
            icon: 'info',
            title: 'Forgot Your Password?',
            html: 'Please contact the <strong>EDP Department</strong> or your system administrator to reset your password.',
            confirmButtonText: 'OK',
            confirmButtonColor: '#f5820a',
            background: '#132d4a',
            color: '#e8f4fd'
        });
    }

    /* ── Password toggle ─────────────────────────────────────── */
    var eyeOnPath  = 'M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z';
    var eyeOffPath = 'M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z';

    document.getElementById('togglePwd').addEventListener('click', function () {
        var pwd     = document.getElementById('Password');
        var eyeIcon = document.getElementById('eyeIcon');
        var isHide  = pwd.type === 'password';
        pwd.type            = isHide ? 'text' : 'password';
        eyeIcon.innerHTML   = '<path d="' + (isHide ? eyeOffPath : eyeOnPath) + '"/>';
    });

    /* ── Login loading state ─────────────────────────────────── */
    document.getElementById('loginForm').addEventListener('submit', function () {
        var u = document.getElementById('UserName').value.trim();
        var p = document.getElementById('Password').value.trim();
        if (u && p) {
            var btn = document.getElementById('loginBtn');
            btn.classList.add('loading');
            btn.disabled = true;
        }
    });
</script>
</body>
</html>
