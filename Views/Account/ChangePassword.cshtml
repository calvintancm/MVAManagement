@{
    ViewData["Title"] = "Change Password";
    ViewData["BreadcrumbSection"] = "Account";
    ViewData["BreadcrumbPage"] = "Change Password";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Change Password</h1>
        <p class="page-subtitle">Update your login credentials</p>
    </div>
</div>

<div class="ptc-card">
    <div class="ptc-card-body" style="padding: 24px; max-width: 500px;">
        <div style="margin-bottom: 20px;">
            <i class="bi bi-shield-lock" style="font-size: 32px; color: var(--accent);"></i>
            <h3 style="margin-top: 8px; margin-bottom: 4px;">Password Update</h3>
            <p style="color: var(--text-secondary);">Enter your current password and a new strong password.</p>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label style="font-weight: 600; margin-bottom: 6px; display: block;">Current Password</label>
            <input id="currentPassword" type="password" class="k-textbox" style="width: 100%;" />
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
            <label style="font-weight: 600; margin-bottom: 6px; display: block;">New Password</label>
            <input id="newPassword" type="password" class="k-textbox" style="width: 100%;" />
            <small style="color: var(--text-muted);">Minimum 6 characters.</small>
        </div>

        <div class="form-group" style="margin-bottom: 24px;">
            <label style="font-weight: 600; margin-bottom: 6px; display: block;">Confirm New Password</label>
            <input id="confirmPassword" type="password" class="k-textbox" style="width: 100%;" />
        </div>

        <div>
            <button id="changePwdBtn" class="btn-ptc-primary" style="min-width: 140px;">
                <i class="bi bi-check-lg"></i> Update Password
            </button>
            <button id="resetPwdBtn" class="btn-ptc-outline" style="margin-left: 12px;">
                <i class="bi bi-arrow-clockwise"></i> Clear
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $("#resetPwdBtn").click(function () {
                $("#currentPassword, #newPassword, #confirmPassword").val("");
            });

            $("#changePwdBtn").click(function () {
                var current = $("#currentPassword").val();
                var newPwd = $("#newPassword").val();
                var confirm = $("#confirmPassword").val();

                if (!current || !newPwd || !confirm) {
                    KSwal.toast("error",
                        "All fields are required. If you cannot remember your current password, please contact EDP Support to reset your password.");
                    return;
                }

                if (newPwd !== confirm) {
                    KSwal.toast("error", "New password and confirmation do not match.");
                    return;
                }

                KSwal.loading("Changing password...");

                $.ajax({
                    url: '@Url.Action("ChangePassword", "Account")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        currentPassword: current,
                        newPassword: newPwd,
                        confirmPassword: confirm
                    }),
                    success: function (response) {
                        KSwal.close();
                        if (response.success) {
                            KSwal.toast("success", response.message);
                            $("#resetPwdBtn").click(); // clear form
                        } else {
                            var msg = response.errors ? response.errors.join("\n") : response.message;
                            KSwal.error("Change Failed", msg);
                        }
                    },
                    error: function (xhr) {
                        KSwal.close();
                        var err = xhr.responseJSON;
                        var msg = err && err.errors ? err.errors.join("\n") : (err && err.message) || "Server error.";
                        KSwal.error("Error", msg);
                    }
                });
            });
        });
    </script>
}