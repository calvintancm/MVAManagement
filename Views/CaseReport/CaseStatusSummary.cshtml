@{
    ViewData["Title"] = "Case Status Summary";
    ViewData["BreadcrumbSection"] = "Reports";
    ViewData["BreadcrumbPage"] = "Case Status Summary";

    var statuses    = ViewBag.CaseStatuses  as IEnumerable<MVAManagement.Models.MVA.CaseStatus>  ?? Enumerable.Empty<MVAManagement.Models.MVA.CaseStatus>();
    var caseworkers = ViewBag.Caseworkers   as IEnumerable<MVAManagement.Models.MVA.CaseworkerProfile> ?? Enumerable.Empty<MVAManagement.Models.MVA.CaseworkerProfile>();
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <h1 class="page-title">Case Status Summary</h1>
        <p class="page-subtitle">Distribution of case files by status and caseworker</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn-ptc-primary" onclick="runReport()">
            <i class="bi bi-bar-chart-line"></i> Run Report
        </button>
        <button class="btn-ptc-outline" id="btnExcel" onclick="exportExcel()" disabled>
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </button>
    </div>
</div>

@* Filter Card *@
<div class="ptc-card mb-3">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title"><i class="bi bi-funnel"></i> Report Filters</h2>
    </div>
    <div class="ptc-card-body" style="padding:20px 24px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:18px;">
            <div style="display:flex;flex-direction:column;gap:5px;min-width:150px;">
                <label class="filter-label">Date From (Opened)</label>
                <input type="text" id="dtFrom" class="k-textbox" style="width:150px;" placeholder="dd/MM/yyyy" />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:150px;">
                <label class="filter-label">Date To (Opened)</label>
                <input type="text" id="dtTo" class="k-textbox" style="width:150px;" placeholder="dd/MM/yyyy" />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:175px;">
                <label class="filter-label">Caseworker</label>
                <select id="ddlCaseworker" style="width:175px;"></select>
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:165px;">
                <label class="filter-label">Status</label>
                <select id="ddlStatus" style="width:165px;"></select>
            </div>
            <div style="padding-bottom:1px;">
                <button class="btn-ptc-primary" onclick="runReport()">
                    <i class="bi bi-play-fill"></i> Generate
                </button>
            </div>
        </div>
    </div>
</div>

@* KPI strip — populated by JS *@
<div id="kpiStrip" style="display:none;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:18px;">
    @foreach (var k in new[] {
        new { Id="kpiTotal",    Label="Total Cases",     Icon="bi-folder2-open",    Color="#1d6fa4", Bg="#eff6ff" },
        new { Id="kpiActive",   Label="Active",          Icon="bi-activity",        Color="#16a34a", Bg="#f0fdf4" },
        new { Id="kpiLit",      Label="In Litigation",   Icon="bi-bank2",           Color="#dc2626", Bg="#fef2f2" },
        new { Id="kpiClosed",   Label="Closed",          Icon="bi-archive",         Color="#64748b", Bg="#f8fafc" },
        new { Id="kpiClaimed",  Label="Total Claimed",   Icon="bi-currency-exchange",Color="#7c3aed",Bg="#faf5ff" },
    })
    {
        <div class="ptc-card" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:4px solid @k.Color;">
            <div style="width:38px;height:38px;border-radius:10px;background:@k.Bg;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi @k.Icon" style="font-size:18px;color:@k.Color;"></i>
            </div>
            <div>
                <div id="@k.Id" style="font-size:1.3rem;font-weight:700;line-height:1;color:#0f172a;">—</div>
                <div style="font-size:0.72rem;color:#64748b;margin-top:3px;">@k.Label</div>
            </div>
        </div>
    }
</div>

@* Results — hidden until report runs *@
<div id="reportResults" style="display:none;">

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;">

        @* By Status table *@
        <div class="ptc-card">
            <div class="ptc-card-header">
                <h2 class="ptc-card-title"><i class="bi bi-tags"></i> By Case Status</h2>
            </div>
            <div class="ptc-card-body" style="padding:0;">
                <table style="width:100%;border-collapse:collapse;font-size:0.83rem;" id="tblStatus">
                    <thead>
                        <tr style="background:#f8fafc;font-size:0.75rem;color:#475569;font-weight:600;">
                            <th style="padding:10px 16px;text-align:left;border-bottom:1px solid #e2e8f0;">Status</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">Count</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">In Litigation</th>
                            <th style="padding:10px 16px;text-align:right;border-bottom:1px solid #e2e8f0;">Claimed (MYR)</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyStatus"></tbody>
                </table>
            </div>
        </div>

        @* By Caseworker table *@
        <div class="ptc-card">
            <div class="ptc-card-header">
                <h2 class="ptc-card-title"><i class="bi bi-people"></i> By Caseworker</h2>
            </div>
            <div class="ptc-card-body" style="padding:0;">
                <table style="width:100%;border-collapse:collapse;font-size:0.83rem;" id="tblCaseworker">
                    <thead>
                        <tr style="background:#f8fafc;font-size:0.75rem;color:#475569;font-weight:600;">
                            <th style="padding:10px 16px;text-align:left;border-bottom:1px solid #e2e8f0;">Caseworker</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">Total</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">Active</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">Litigation</th>
                            <th style="padding:10px 16px;text-align:center;border-bottom:1px solid #e2e8f0;">Closed</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyCaseworker"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Loading overlay *@
<div id="reportLoading" style="display:none;text-align:center;padding:48px;">
    <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem;"></div>
    <div style="margin-top:12px;color:#64748b;font-size:0.88rem;">Generating report...</div>
</div>

@section Scripts {
<script>
var statuses    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statuses.Select(s => new { s.Id, s.StatusName, s.StatusCode })));
var caseworkers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(caseworkers.Select(c => new { c.Id, c.FullName })));

var statusColorMap = {
    'ACT':{ bg:'#dbeafe',color:'#1d40ae' },'NEG':{ bg:'#fef9c3',color:'#854d0e' },
    'LIT':{ bg:'#fee2e2',color:'#991b1b' },'SET':{ bg:'#dcfce7',color:'#166534' },
    'CLO':{ bg:'#f1f5f9',color:'#475569' },'WIT':{ bg:'#fce7f3',color:'#9d174d' }
};

$(function () {
    kendo.culture('en-GB');
    $('#dtFrom,#dtTo').kendoDatePicker({ format: 'dd/MM/yyyy', culture: 'en-GB' });
    $('#ddlCaseworker').kendoDropDownList({
        dataTextField:'FullName', dataValueField:'Id', optionLabel:'All Caseworkers',
        dataSource: caseworkers || []
    });
    $('#ddlStatus').kendoDropDownList({
        dataTextField:'StatusName', dataValueField:'Id', optionLabel:'All Statuses',
        dataSource: statuses || []
    });
    // Auto-run on load
    runReport();
});

function getParams() {
    var dpFrom = $('#dtFrom').data('kendoDatePicker');
    var dpTo   = $('#dtTo').data('kendoDatePicker');
    return {
        dateFrom:    dpFrom && dpFrom.value() ? dpFrom.value().toISOString() : '',
        dateTo:      dpTo   && dpTo.value()   ? dpTo.value().toISOString()   : '',
        caseworkerId:$('#ddlCaseworker').data('kendoDropDownList') ? $('#ddlCaseworker').data('kendoDropDownList').value() : '',
        statusId:    $('#ddlStatus').data('kendoDropDownList') ? $('#ddlStatus').data('kendoDropDownList').value() : '',
        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    };
}

function runReport() {
    $('#reportResults,#kpiStrip').hide();
    $('#reportLoading').show();

    $.post('@Url.Action("CaseStatusSummaryData","Report")', getParams(), function (r) {
        $('#reportLoading').hide();
        if (!r || r.success === false) { KSwal.error('Error', r.message || 'Failed.'); return; }

        // KPIs
        $('#kpiTotal').text(r.total || 0);
        $('#kpiActive').text(r.active || 0);
        $('#kpiLit').text(r.inLitigation || 0);
        $('#kpiClosed').text(r.closed || 0);
        $('#kpiClaimed').text('RM ' + kendo.toString(r.totalClaimed || 0, 'n2'));
        $('#kpiStrip').css('display','grid');

        // By Status
        var tbody = $('#tbodyStatus').empty();
        (r.byStatus || []).forEach(function(s, i) {
            var map = statusColorMap[s.StatusCode] || { bg:'#e2e8f0', color:'#475569' };
            var badge = '<span style="background:' + map.bg + ';color:' + map.color
                + ';padding:2px 8px;border-radius:20px;font-size:0.71rem;font-weight:700;">'
                + $('<div>').text(s.StatusName).html() + '</span>';
            tbody.append('<tr style="' + (i%2===0?'':'background:#f8fafc;') + '">'
                + '<td style="padding:9px 16px;">' + badge + '</td>'
                + '<td style="padding:9px 16px;text-align:center;font-weight:700;">' + s.Count + '</td>'
                + '<td style="padding:9px 16px;text-align:center;">' + s.InLitigation + '</td>'
                + '<td style="padding:9px 16px;text-align:right;font-variant-numeric:tabular-nums;">RM '
                + kendo.toString(s.TotalClaimed,'n2') + '</td></tr>');
        });

        // By Caseworker
        var tbody2 = $('#tbodyCaseworker').empty();
        (r.byCaseworker || []).forEach(function(c, i) {
            tbody2.append('<tr style="' + (i%2===0?'':'background:#f8fafc;') + '">'
                + '<td style="padding:9px 16px;font-weight:600;">' + $('<div>').text(c.CaseworkerName).html() + '</td>'
                + '<td style="padding:9px 16px;text-align:center;font-weight:700;">' + c.Count + '</td>'
                + '<td style="padding:9px 16px;text-align:center;color:#16a34a;">' + c.Active + '</td>'
                + '<td style="padding:9px 16px;text-align:center;color:#dc2626;">' + c.InLitigation + '</td>'
                + '<td style="padding:9px 16px;text-align:center;color:#64748b;">' + c.Closed + '</td></tr>');
        });

        $('#reportResults').show();
        $('#btnExcel').prop('disabled', false);
    }).fail(function(){ $('#reportLoading').hide(); KSwal.error('Error','Server error.'); });
}

function exportExcel() {
    var params = getParams();
    var form = $('<form method="POST" action="@Url.Action("CaseStatusSummaryExcel","Report")">');
    $.each(params, function(k,v){ form.append($('<input type="hidden">').attr('name',k).val(v)); });
    $('body').append(form); form.submit(); form.remove();
    KSwal.toast('info','Preparing Excel file...');
}
</script>
}
