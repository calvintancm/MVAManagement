@{
    ViewData["Title"] = "Settlement Summary";
    ViewData["BreadcrumbSection"] = "Reports";
    ViewData["BreadcrumbPage"] = "Settlement Summary";

    var caseworkers = ViewBag.Caseworkers as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <h1 class="page-title">Settlement Summary</h1>
        <p class="page-subtitle">Accepted settlements, recovery ratios, and negotiation pipeline</p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn-ptc-primary" onclick="runReport()">
            <i class="bi bi-play-fill"></i> Run Report
        </button>
        <button class="btn-ptc-outline" id="btnExcel" onclick="exportExcel()" disabled>
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </button>
    </div>
</div>

@* Filter Card *@
<div class="ptc-card mb-3">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title"><i class="bi bi-funnel"></i> Report Filters</h2>
    </div>
    <div class="ptc-card-body" style="padding:20px 24px;">
        <div style="display:flex;flex-wrap:wrap;align-items:flex-end;gap:18px;">
            <div style="display:flex;flex-direction:column;gap:5px;min-width:150px;">
                <label class="filter-label">Offer Date From</label>
                <input type="text" id="dtFrom" class="k-textbox" style="width:150px;" placeholder="dd/MM/yyyy" />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:150px;">
                <label class="filter-label">Offer Date To</label>
                <input type="text" id="dtTo" class="k-textbox" style="width:150px;" placeholder="dd/MM/yyyy" />
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:175px;">
                <label class="filter-label">Caseworker</label>
                <select id="ddlCaseworker" style="width:175px;"></select>
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;min-width:155px;">
                <label class="filter-label">Offer Status</label>
                <select id="ddlOfferStatus" style="width:155px;"></select>
            </div>
            <div style="padding-bottom:1px;">
                <button class="btn-ptc-primary" onclick="runReport()">
                    <i class="bi bi-play-fill"></i> Generate
                </button>
            </div>
        </div>
    </div>
</div>

@* KPI strip *@
<div id="kpiStrip" style="display:none;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:18px;">
    @foreach (var k in new[] {
        new { Id="kpiTotal",    Label="Total Offers",      Icon="bi-chat-square-text",  Color="#1d6fa4", Bg="#eff6ff" },
        new { Id="kpiAccepted", Label="Accepted",          Icon="bi-check-circle",      Color="#16a34a", Bg="#f0fdf4" },
        new { Id="kpiClaimed",  Label="Total Claimed",     Icon="bi-currency-exchange", Color="#7c3aed", Bg="#faf5ff" },
        new { Id="kpiSettled",  Label="Total Settled",     Icon="bi-cash-stack",        Color="#0e7490", Bg="#ecfeff" },
        new { Id="kpiRatio",    Label="Recovery Ratio",    Icon="bi-graph-up-arrow",    Color="#d97706", Bg="#fffbeb" },
    })
    {
        <div class="ptc-card" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:4px solid @k.Color;">
            <div style="width:38px;height:38px;border-radius:10px;background:@k.Bg;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi @k.Icon" style="font-size:18px;color:@k.Color;"></i>
            </div>
            <div>
                <div id="@k.Id" style="font-size:1.2rem;font-weight:700;line-height:1;color:#0f172a;">—</div>
                <div style="font-size:0.72rem;color:#64748b;margin-top:3px;">@k.Label</div>
            </div>
        </div>
    }
</div>

<div id="reportResults" style="display:none;">

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;margin-bottom:18px;">

        @* Offer detail table *@
        <div class="ptc-card">
            <div class="ptc-card-header">
                <h2 class="ptc-card-title"><i class="bi bi-currency-exchange"></i> Offer Register</h2>
                <span id="recordCount" class="record-count-badge">0 records</span>
            </div>
            <div class="ptc-card-body" style="padding:0;max-height:480px;overflow-y:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:0.82rem;">
                    <thead style="position:sticky;top:0;z-index:1;">
                        <tr style="background:#f8fafc;font-size:0.75rem;color:#475569;font-weight:600;">
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:left;">File No.</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:left;">Claimant</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:center;">Date</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:left;">Direction</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:right;">Offer (MYR)</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:center;">Recovery %</th>
                            <th style="padding:10px 14px;border-bottom:1px solid #e2e8f0;text-align:center;">Status</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyOffers"></tbody>
                </table>
            </div>
        </div>

        @* By status breakdown *@
        <div class="ptc-card">
            <div class="ptc-card-header">
                <h2 class="ptc-card-title"><i class="bi bi-pie-chart"></i> By Offer Status</h2>
            </div>
            <div class="ptc-card-body" style="padding:0;">
                <table style="width:100%;border-collapse:collapse;font-size:0.83rem;">
                    <thead>
                        <tr style="background:#f8fafc;font-size:0.75rem;color:#475569;font-weight:600;">
                            <th style="padding:10px 16px;border-bottom:1px solid #e2e8f0;text-align:left;">Status</th>
                            <th style="padding:10px 16px;border-bottom:1px solid #e2e8f0;text-align:center;">Count</th>
                            <th style="padding:10px 16px;border-bottom:1px solid #e2e8f0;text-align:right;">Total (MYR)</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyStatus"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="reportLoading" style="display:none;text-align:center;padding:48px;">
    <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem;"></div>
    <div style="margin-top:12px;color:#64748b;font-size:0.88rem;">Generating report...</div>
</div>

@section Scripts {
<script>
var caseworkers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    caseworkers.Select(c => new { Id = (int)c.Id, FullName = (string)c.FullName })));

var offerStatuses = ['Open','Accepted','Rejected','Countered','Lapsed'];
var statusColorMap = {
    'Open':       { bg:'#fef3c7', color:'#92400e' },
    'Accepted':   { bg:'#dcfce7', color:'#166534' },
    'Rejected':   { bg:'#fee2e2', color:'#991b1b' },
    'Countered':  { bg:'#e0e7ff', color:'#3730a3' },
    'Lapsed':     { bg:'#f1f5f9', color:'#475569' }
};
var dirStyleMap = {
    'From Insurer': { bg:'#dbeafe', color:'#1d40ae' },
    'Counter Offer':{ bg:'#fce7f3', color:'#9d174d' }
};

$(function () {
    kendo.culture('en-GB');
    $('#dtFrom,#dtTo').kendoDatePicker({ format:'dd/MM/yyyy', culture:'en-GB' });

    // Default: current year
    var now = new Date();
    $('#dtFrom').data('kendoDatePicker').value(new Date(now.getFullYear(), 0, 1));
    $('#dtTo').data('kendoDatePicker').value(now);

    $('#ddlCaseworker').kendoDropDownList({
        dataTextField:'FullName', dataValueField:'Id', optionLabel:'All Caseworkers',
        dataSource: caseworkers || []
    });
    $('#ddlOfferStatus').kendoDropDownList({
        dataSource: offerStatuses, optionLabel: 'All Statuses'
    });
    runReport();
});

function getParams() {
    var dpFrom = $('#dtFrom').data('kendoDatePicker');
    var dpTo   = $('#dtTo').data('kendoDatePicker');
    return {
        dateFrom:     dpFrom && dpFrom.value() ? dpFrom.value().toISOString() : '',
        dateTo:       dpTo   && dpTo.value()   ? dpTo.value().toISOString()   : '',
        caseworkerId: $('#ddlCaseworker').data('kendoDropDownList') ? $('#ddlCaseworker').data('kendoDropDownList').value() : '',
        offerStatus:  $('#ddlOfferStatus').data('kendoDropDownList') ? $('#ddlOfferStatus').data('kendoDropDownList').value() : '',
        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    };
}

function runReport() {
    $('#reportResults,#kpiStrip').hide();
    $('#reportLoading').show();

    $.post('@Url.Action("SettlementSummaryData","FinancialReport")', getParams(), function (r) {
        $('#reportLoading').hide();
        if (!r || r.success === false) { KSwal.error('Error', r.message || 'Failed.'); return; }

        $('#kpiTotal').text(r.total || 0);
        $('#kpiAccepted').text(r.acceptedCount || 0);
        $('#kpiClaimed').text('RM ' + kendo.toString(r.totalClaimed || 0, 'n2'));
        $('#kpiSettled').text('RM ' + kendo.toString(r.totalSettled || 0, 'n2'));
        $('#kpiRatio').text((r.recoveryRatio || 0) + '%');
        $('#kpiStrip').css('display','grid');
        $('#recordCount').text((r.total||0) + ' records');

        // Offer rows
        var tbody = $('#tbodyOffers').empty();
        (r.rows || []).forEach(function(o, i) {
            var sMap = statusColorMap[o.OfferStatus] || { bg:'#e2e8f0', color:'#475569' };
            var dMap = dirStyleMap[o.OfferDirection] || { bg:'#e2e8f0', color:'#475569' };
            var rowBg = o.OfferStatus==='Accepted' ? '#f0fdf4' : o.OfferStatus==='Rejected' ? '#fff5f5' : (i%2===0?'':'#f8fafc');
            var recBadge = o.RecoveryRatioPct !== null
                ? '<span style="font-size:0.78rem;font-weight:700;color:' + (o.RecoveryRatioPct>=70?'#16a34a':o.RecoveryRatioPct>=50?'#d97706':'#dc2626') + ';">' + o.RecoveryRatioPct + '%</span>'
                : '<span style="color:#94a3b8;">—</span>';
            var offerDate = o.OfferDate ? kendo.toString(kendo.parseDate(o.OfferDate),'dd/MM/yyyy') : '—';
            tbody.append('<tr style="border-bottom:1px solid #f1f5f9;background:' + rowBg + ';">'
                + '<td style="padding:8px 14px;"><a href="@Url.Action("EditCase","Case")?id=' + o.CaseFileId
                + '" style="font-family:monospace;font-weight:700;font-size:0.82rem;color:#1d6fa4;">'
                + $('<div>').text(o.FileNumber||'').html() + '</a></td>'
                + '<td style="padding:8px 14px;font-size:0.8rem;">' + $('<div>').text(o.ClaimantName||'').html() + '</td>'
                + '<td style="padding:8px 14px;text-align:center;">' + offerDate + '</td>'
                + '<td style="padding:8px 14px;"><span style="background:' + dMap.bg + ';color:' + dMap.color + ';padding:2px 7px;border-radius:20px;font-size:0.7rem;font-weight:700;">' + $('<div>').text(o.OfferDirection||'').html() + '</span></td>'
                + '<td style="padding:8px 14px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;">RM ' + kendo.toString(o.OfferAmount,'n2') + '</td>'
                + '<td style="padding:8px 14px;text-align:center;">' + recBadge + '</td>'
                + '<td style="padding:8px 14px;text-align:center;"><span style="background:' + sMap.bg + ';color:' + sMap.color + ';padding:2px 7px;border-radius:20px;font-size:0.7rem;font-weight:700;">' + $('<div>').text(o.OfferStatus||'').html() + '</span></td>'
                + '</tr>');
        });

        // By status
        var tbody2 = $('#tbodyStatus').empty();
        (r.byStatus || []).forEach(function(s, i) {
            var sMap = statusColorMap[s.Status] || { bg:'#e2e8f0', color:'#475569' };
            tbody2.append('<tr style="border-bottom:1px solid #f1f5f9;' + (i%2===0?'':'background:#f8fafc;') + '">'
                + '<td style="padding:9px 16px;"><span style="background:' + sMap.bg + ';color:' + sMap.color + ';padding:2px 9px;border-radius:20px;font-size:0.71rem;font-weight:700;">' + $('<div>').text(s.Status).html() + '</span></td>'
                + '<td style="padding:9px 16px;text-align:center;font-weight:700;">' + s.Count + '</td>'
                + '<td style="padding:9px 16px;text-align:right;font-variant-numeric:tabular-nums;">RM ' + kendo.toString(s.TotalAmount,'n2') + '</td>'
                + '</tr>');
        });

        $('#reportResults').show();
        $('#btnExcel').prop('disabled', false);
    }).fail(function(){ $('#reportLoading').hide(); KSwal.error('Error','Server error.'); });
}

function exportExcel() {
    var p = getParams();
    var form = $('<form method="POST" action="@Url.Action("SettlementSummaryExcel","FinancialReport")">');
    $.each(p, function(k,v){ form.append($('<input type="hidden">').attr('name',k).val(v)); });
    $('body').append(form); form.submit(); form.remove();
    KSwal.toast('info','Preparing Excel file...');
}
</script>
}
