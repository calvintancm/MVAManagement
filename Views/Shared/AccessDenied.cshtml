@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied — LegalCase MVA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body {
            height: 100%;
            font-family: 'Outfit', sans-serif;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            background: #fff;
            border-radius: 16px;
            padding: 48px 52px;
            text-align: center;
            max-width: 480px;
            width: 100%;
            box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        }
        .icon-wrap {
            width: 72px; height: 72px;
            background: #fee2e2;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
        }
        .icon-wrap svg { width: 36px; height: 36px; fill: #dc2626; }
        .code {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 3.5rem;
            font-weight: 800;
            color: #dc2626;
            line-height: 1;
            margin-bottom: 8px;
        }
        .title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.35rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 12px;
        }
        .message {
            font-size: 0.9rem;
            color: #64748b;
            line-height: 1.65;
            margin-bottom: 32px;
        }
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #1d6fa4;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 12px 28px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .btn-back:hover { opacity: 0.85; }
        .btn-home {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 28px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
            margin-left: 10px;
        }
        .btn-home:hover { background: #e2e8f0; }
        .footer-note {
            margin-top: 28px;
            font-size: 0.76rem;
            color: #94a3b8;
        }
    </style>
</head>
<body>
<div class="card">
    <div class="icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>
        </svg>
    </div>

    <div class="code">403</div>
    <div class="title">Access Denied</div>
    <p class="message">
        You don't have permission to view this page.<br>
        Please contact your system administrator to request access.
    </p>

    <div>
        <a href="javascript:history.back()" class="btn-back">
            ← Go Back
        </a>
        <a href="@Url.Action("Index", "Dashboard")" class="btn-home">
            🏠 Dashboard
        </a>
    </div>

    <p class="footer-note">
        LegalCase MVA &mdash; If you believe this is an error, contact your Admin.
    </p>
</div>
</body>
</html>
